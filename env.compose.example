# Renomme ou copie ce fichier vers .env dans le même dossier que docker-compose.yml
# (Docker Compose lit automatiquement .env pour substituer ${VAR}).

MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306
BACKEND_PORT=8080
FRONTEND_PORT=5176

DB_NAME=conges_db
DB_APP_USER=conges_app
DB_APP_PASSWORD=conges_app_password
SPRING_PROFILES_ACTIVE=dev

# API Dolibarr vue DEPUIS le conteneur backend :
# - Dolibarr sur ta machine (XAMPP, etc.) :
#   DOLIBARR_URL=http://host.docker.internal/dolibarr/api/index.php
# - Dolibarr lancé avec : docker compose --profile dolibarr up
#   DOLIBARR_URL=http://dolibarr/api/index.php

DOLIBARR_URL=http://host.docker.internal/dolibarr/api/index.php

# Profil dolibarr uniquement
DOLIBARR_HTTP_PORT=8090
DOLIBARR_DB_NAME=dolibarr
DOLIBARR_DB_USER=root
DOLIBARR_DB_PASSWORD=root
